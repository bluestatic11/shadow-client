{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shadow Client",
  "version": "0.2.13",
  "identifier": "app.shadowclient.launcher",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Shadow Client",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "appimage", "deb"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "../../client.py",
      "../../auth.py",
      "../../mojang.py",
      "../../fabric.py",
      "../../mods.py",
      "../../jvm.py",
      "../../jdk.py",
      "../../branding/hud_mod/src/**/*",
      "../../branding/hud_mod/stubs/**/*",
      "../../branding/hud_mod/resources/**/*",
      "../../branding/hud_mod/build.py"
    ],
    "category": "Game",
    "shortDescription": "Minecraft client with Lunar-grade UX, 3× the FPS",
    "longDescription": "Shadow Client is a free Minecraft 1.21 client. Bundles Sodium / Iris / FerriteCore / Lithium / 130+ HUD modules / drag-to-position editor.",
    "publisher": "Edison",
    "homepage": "https://shadowclient.app",
    "windows": {
      "wix": { "language": ["en-US"] },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://shadowclient.app/updates/{{target}}/{{current_version}}"
      ],
      "dialog": true
    }
  }
}
